# X API OAuth 2.0 — app name: eriks-knowledge-base
# developer.x.com → eriks-knowledge-base → Keys and tokens
X_CLIENT_ID=your_client_id_here
X_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you set under App → User authentication settings → Callback URI
X_REDIRECT_URI=http://127.0.0.1:8765/callback