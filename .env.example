# LLM Wiki engine locations. WIKI_VAULT is required: the Obsidian vault wiki
# root — the directory that holds index.md. Raw sources default to its sibling
# (<vault>/../raw); override with WIKI_RAW only if they live elsewhere.
#
# This .env is discovered automatically: the engine searches the working
# directory and its parents, then this repo, then ~/.config/erik-wiki/.env. A
# real exported environment variable always wins over the value here.
#
# After setting WIKI_VAULT, run `uv run wiki-init` to seed the vault from the
# shipped template and build the search index, or `uv run wiki-doctor` to check
# what is missing.
WIKI_VAULT=
# WIKI_RAW=

# X API OAuth 2.0 — app: eriks-knowledge-base
# developer.x.com → Keys and tokens

X_CLIENT_ID=
X_CLIENT_SECRET=

# Local dev: use Native App + custom hostname (X often rejects 127.0.0.1/localhost).
#   sudo sh -c 'echo "127.0.0.1 xoauth.local" >> /etc/hosts'
# Portal callback + website must match exactly.
X_APP_TYPE=native
X_REDIRECT_URI=http://xoauth.local:8765/callback